# Go API Environment Variables
PORT=8080
DATABASE_URL=user:password@tcp(localhost:3306)/campsite_go?charset=utf8mb4&parseTime=True&loc=Local

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=user
DB_PASSWORD=password
DB_NAME=campsite_go

# File Storage
UPLOADS_DIR=./uploads
MAX_UPLOAD_SIZE=100MB

# CORS Configuration  
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization

# Logging
LOG_LEVEL=info